# ─── SEO / Search Console verification ──────────────────────────────
# Google Search Console → choose "HTML tag" method, paste the token here.
GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools verification token (msvalidate.01).
BING_SITE_VERIFICATION=

# ─── Analytics (optional, privacy-friendly, rendered only if set) ────
# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# Plausible domain, e.g. ossamaelhakki.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ─── Social ─────────────────────────────────────────────────────────
# Twitter/X handle incl. @, e.g. @ossamaelhakki (adds twitter:site/creator)
NEXT_PUBLIC_TWITTER_HANDLE=

# ─── IndexNow (Bing/Yandex instant indexing) ────────────────────────
# Key must match the file public/<key>.txt. Default already set up.
INDEXNOW_KEY=8e4b1d7a9c2f43e6b0a5d8c1f6e3a92b

# ─── Vercel Cron (IndexNow route protection) ───────────────────────
# Any random string; Vercel Cron sends it as Authorization: Bearer <value>
CRON_SECRET=

# ─── Contact form (Resend) ─────────────────────────────────────────
# Create a key at resend.com (Dashboard -> API Keys). Server-side only.
RESEND_API_KEY=
